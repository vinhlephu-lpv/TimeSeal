rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /capsules/{ownerId}/{capsuleId}/{fileName} {
      // Original media is served only through short-lived signed URLs from Functions.
      allow read: if false;
      allow create: if isSignedIn() && request.auth.uid == ownerId;
      allow update, delete: if false;
    }

    match /capsules/{capsuleId}/{fileName} {
      allow read, write: if false;
    }

    match /avatars/{userId}/{fileName} {
      // Avatar reads are metered by Functions before a short-lived signed URL is issued.
      allow read: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if false;
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
