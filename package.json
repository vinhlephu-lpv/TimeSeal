{
  "name": "TimeSeal_AuraSoft_Systems",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "qa:smoke": "npm run lint && npx tsc --noEmit && npx jest --runInBand",
    "qa:functions": "npm --prefix functions run build",
    "android:clean": "cd android && gradlew clean",
    "android:bundle:release": "cd android && gradlew bundleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a",
    "android:apk:release": "cd android && gradlew assembleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a",
    "firebase:deploy": "firebase deploy --only firestore:rules,firestore:indexes,storage,functions",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage",
    "firebase:deploy:functions": "firebase deploy --only functions"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/database": "^24.0.0",
    "@react-native-firebase/firestore": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-firebase/storage": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native/new-app-screen": "0.85.2",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "lottie-react-native": "^7.3.8",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-biometrics": "^3.0.1",
    "react-native-compressor": "^1.18.2",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-image-picker": "^8.2.1",
    "react-native-permissions": "^5.5.1",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-sound": "^0.13.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-video": "^6.19.2",
    "react-native-view-shot": "^4.0.3",
    "react-native-worklets": "^0.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
