rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasSafeNewUserSubscription() {
      return request.resource.data.isPremium == false &&
        request.resource.data.plan == 'free' &&
        !('previousPlan' in request.resource.data) &&
        !('premiumSource' in request.resource.data) &&
        !('premiumUpdatedAtISO' in request.resource.data) &&
        !('subscriptionMeta' in request.resource.data);
    }

    function doesNotWriteRewardedCapsuleSlots() {
      return !('rewardedCapsuleSlots' in request.resource.data) ||
        (resource.data != null && 
         'rewardedCapsuleSlots' in resource.data && 
         request.resource.data.rewardedCapsuleSlots == resource.data.rewardedCapsuleSlots);
    }


    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && hasSafeNewUserSubscription();
      allow update: if isOwner(userId) && doesNotWriteRewardedCapsuleSlots();
      allow delete: if isOwner(userId);
    }

    match /capsules/{capsuleId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid in resource.data.members
      );
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.auth.uid in request.resource.data.members
        )
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
    }

    match /user_storage_items/{itemId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.ownerId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow update: if isSignedIn() &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /invites/{inviteToken} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.invitedBy;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.invitedBy;
    }

    match /avatar_uploads/{userId} {
      allow read, create, update, delete: if false;
    }
  }
}
